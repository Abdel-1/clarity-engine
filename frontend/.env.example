# Frontend environment template — copy to .env for local dev if needed.
#
# Base URL of the backend API service (NO trailing slash, NO /api suffix —
# the code appends /api where required).
#   - Local dev:  leave unset; the code falls back to http://127.0.0.1:8000
#   - Production: set to your deployed backend URL, e.g.
#       VITE_API_URL=https://clarity-backend.up.railway.app
#
# NOTE: Vite inlines this at BUILD time, so it must be set on the frontend
# service BEFORE/at build, then rebuild/redeploy after changing it.
VITE_API_URL=
