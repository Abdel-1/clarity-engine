# Clarity Engine — environment variables template
# Copy to .env and fill in the values. Never commit .env.

APP_NAME=ClarityEngine
DEBUG=False
DATABASE_URL=sqlite:///./clarity.db
SECRET_KEY=change-me-use-a-long-random-string

# DeepSeek AI (OpenAI-compatible)
# Get your key at https://platform.deepseek.com
DEEPSEEK_API_KEY=
# Timeout in seconds for DeepSeek API calls (30 — non-thinking responses are fast)
DEEPSEEK_TIMEOUT=30
# Set to "on" to re-enable deepseek-v4-pro hidden thinking (slower; for before/after measurement). Default: disabled.
# DEEPSEEK_THINKING=off

# CORS — comma-separated allowed front-end origins. Set to your production origin.
# Never use "*" together with credentials. Default covers the local Vite dev server.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Abuse / cost controls
# Per-user burst cap on the analyze endpoints, per minute, per process (0 = off).
ANALYZE_BURST_PER_MINUTE=15
# Per-client daily token budget, summed from recorded analyses (0 = unlimited).
# Example: 2000000 ≈ a few hundred analyses/day per client.
TENANT_DAILY_TOKEN_BUDGET=0
